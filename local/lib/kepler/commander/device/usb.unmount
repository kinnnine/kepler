#!/bin/bash

case $ROFI_RETV in
	0)
		list=$(lsblk -nr --output='NAME,SIZE,MOUNTPOINTS,TYPE' | grep -v mmc | grep media | awk '{ print "󱊞 " $1 " " $2 " " $3 }')
		echo -en "󰌍 Go Back...\n"
		echo -en "${list}\n"
		;;
	1)
		selection="$(awk '{ print tolower($2) }' <<< "$@")"
		if [ "$selection" = "go" ]; then
			coproc ( rofi -show device.usb -modes "device.usb:~/.local/lib/kepler/commander/device/usb" )
		else
			coproc ( udisksctl unmount --no-user-interaction -b /dev/$selection && notify-send "Unmounted" "$selection" )
		fi
		;;
esac
